# PostgreSQL (Supabase or local Docker)
POSTGRES_DB=cafe_koi
POSTGRES_USER=cafe_user
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-in-production-use-50-random-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend-inventory

# Database URL (used by Django via django-environ and by Prisma)
DATABASE_URL=postgresql://cafe_user:supersecretpassword@db:5432/cafe_koi

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Supabase (optional — only when using Supabase Cloud instead of local db service)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Node/Fastify POS
NODE_ENV=development
PORT=3000

# Frontend
VITE_API_INVENTORY_URL=http://localhost:8000/api
VITE_API_POS_URL=http://localhost:3000/api
